# Copie para .env e ajuste antes do deploy.
# Nao use estes valores em producao.

TZ=America/Fortaleza

# PostgreSQL principal da VM1
POSTGRES_DB=hotspot_academia_prod
POSTGRES_USER=hotspot_prod_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD
DATABASE_URL=postgresql://hotspot_prod_user:CHANGE_ME_STRONG_POSTGRES_PASSWORD@postgres:5432/hotspot_academia_prod

# Rede de producao
CCR_IP=CHANGE_ME_CCR1036_OR_NAS_IP
VM1_PUBLIC_IP=0.0.0.0
VM1_BIND_IP=0.0.0.0
PORTAL_DOMAIN=hotspot.example.com

# Portal
PORTAL_BRAND_NAME=Wi-Fi Academia
PORTAL_BRAND_TAGLINE=Acesso Wi-Fi para alunos e visitantes autorizados.
PORTAL_SHOW_RADIUS_PASSWORD=false
PORTAL_UPLOAD_DIR=/app/data/uploads
PORTAL_MAX_IMAGE_BYTES=2097152
PORTAL_SESSION_SECRET=CHANGE_ME_LONG_RANDOM_SESSION_SECRET
PORTAL_TERMO_VERSAO=prod-1
PORTAL_RADIUS_RATE_LIMIT=10M/5M
PORTAL_DEFAULT_CLIENTE_NOME=Cliente Academia
PORTAL_DEFAULT_CLIENTE_DOCUMENTO=CHANGE_ME_CNPJ
PORTAL_DEFAULT_UNIDADE_NOME=Unidade Principal
PORTAL_DEFAULT_UNIDADE_IDENTIFICADOR=unidade-principal

# Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD

# FreeRADIUS
RADIUS_SECRET=CHANGE_ME_STRONG_RADIUS_SECRET

# Backup para VM2.
# Exemplo restic REST: rest:https://backup-user:CHANGE_ME_BACKUP_HTTP_PASSWORD@backup.example.com:8000/vm1
BACKUP_VM2_HOST=backup.example.com
BACKUP_VM2_PORT=8000
BACKUP_VM2_USER=backup-user
BACKUP_REPOSITORY=rest:https://CHANGE_ME_BACKUP_USER:CHANGE_ME_BACKUP_HTTP_PASSWORD@backup.example.com:8000/vm1
RESTIC_PASSWORD=CHANGE_ME_STRONG_RESTIC_ENCRYPTION_PASSWORD
RESTIC_KEEP_DAILY=7
RESTIC_KEEP_WEEKLY=4
RESTIC_KEEP_MONTHLY=12
